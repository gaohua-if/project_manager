    "echarts": "^6.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.15.1",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "24.10.1",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
